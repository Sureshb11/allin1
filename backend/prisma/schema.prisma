generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id            String         @id @default(cuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  email         String         @unique
  phone         String?        @unique
  passwordHash  String
  firstName     String
  lastName      String
  avatarUrl     String?
  bio           String?
  plan          String         @default("free")
  proUntil      DateTime?
  city          String?
  country       String?
  district      String?
  pincode       String?
  state         String?
  coverUrl      String?
  chatRooms     ChatMember[]
  chatMessages  ChatMessage[]
  notifications Notification[]
  players       Player[]
  products      Product[]
  ownedTeams    Team[]         @relation("ownedTeams")
  teamFollows   TeamFollow[]
  badges        UserBadge[]
  sports        UserSport[]
  devices       DeviceToken[]
}

// A device's FCM registration token — one row per install per user, so a push
// reaches every device someone is signed in on. Tokens are rotated by FCM, and
// dead ones are pruned when a send reports them unregistered.
model DeviceToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  token     String   @unique
  platform  String   @default("android")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserSport {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  sport     String
  isPrimary Boolean  @default(false)
  role      String?
  skill     String?
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, sport])
  @@index([sport])
}

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  data      Json?
  user      User     @relation(fields: [userId], references: [id])

  // The bell screen reads "my notifications, newest first" — without this the
  // lookup is a sequential scan over every row in the table.
  @@index([userId, createdAt])
  // Unread badge counts.
  @@index([userId, read])
}

model Team {
  id              String           @id @default(cuid())
  name            String
  city            String?
  logoUrl         String?
  achievements    String?
  bio             String?
  colors          String?
  country         String?
  foundedYear     Int?
  homeGround      String?
  state           String?
  sport           String           @default("cricket")
  ownerId         String?
  coverUrl        String?
  awards          Json?
  chatRoomId      String?
  battingInnings  Inning[]         @relation("battingTeam")
  bowlingInnings  Inning[]         @relation("bowlingTeam")
  team1Matches    Match[]          @relation("team1")
  team2Matches    Match[]          @relation("team2")
  matchPlayers    MatchPlayer[]
  players         Player[]
  owner           User?            @relation("ownedTeams", fields: [ownerId], references: [id])
  followers       TeamFollow[]
  tournamentTeams TournamentTeam[]

  @@index([sport])
  @@index([ownerId])
}

model TeamJoinRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  teamId    String
  userId    String
  status    String   @default("pending")
  note      String?

  @@unique([teamId, userId])
  @@index([teamId, status])
  @@index([userId])
}

model TeamFollow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
}

model Player {
  id              String        @id @default(cuid())
  name            String
  role            String
  teamId          String?
  stats           Json?
  sport           String        @default("cricket")
  userId          String?
  isAdmin         Boolean       @default(false)
  jerseyNumber    Int?
  isCaptain       Boolean       @default(false)
  isViceCaptain   Boolean       @default(false)
  ballsFaced      Ball[]        @relation("facingBatter")
  ballsBowled     Ball[]        @relation("ballBowler")
  ballsNonStriker Ball[]        @relation("nonStriker")
  matchPlayers    MatchPlayer[]
  oversBowled     Over[]
  team            Team?         @relation(fields: [teamId], references: [id])
  user            User?         @relation(fields: [userId], references: [id])

  @@index([sport])
  @@index([userId])
  @@index([teamId])
}

model Match {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  team1Id        String
  team2Id        String
  status         String
  score1         String?
  score2         String?
  venue          String?
  matchType      String?
  startTime      DateTime?
  currentInnings Int           @default(1)
  overs          Int?
  tossDecision   String?
  tossWinnerId   String?
  result         String?
  sport          String        @default("cricket")
  ballType       String?
  scorerId       String?
  createdBy      String?
  innings        Inning[]
  team1          Team          @relation("team1", fields: [team1Id], references: [id])
  team2          Team          @relation("team2", fields: [team2Id], references: [id])
  squads         MatchPlayer[]
  sportEvents    SportEvent[]

  @@index([sport, status])
  @@index([startTime])
  @@index([createdBy])
}

model SportEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  matchId   String
  sport     String
  teamId    String
  playerId  String?
  eventType String
  value     Int      @default(1)
  period    String?
  periodNum Int?
  metadata  Json?
  match     Match    @relation(fields: [matchId], references: [id])

  @@index([matchId])
  @@index([sport])
}

model MatchPlayer {
  id        String  @id @default(cuid())
  matchId   String
  teamId    String
  playerId  String
  isCaptain Boolean @default(false)
  isWk      Boolean @default(false)
  match     Match   @relation(fields: [matchId], references: [id])
  player    Player  @relation(fields: [playerId], references: [id])
  team      Team    @relation(fields: [teamId], references: [id])

  @@unique([matchId, playerId])
  @@index([playerId])
  @@index([teamId])
}

model Inning {
  id              String  @id @default(cuid())
  matchId         String
  targetScore     Int?
  inningNumber    Int
  battingTeamId   String
  bowlingTeamId   String
  totalRuns       Int     @default(0)
  totalWickets    Int     @default(0)
  extras          Json?
  totalOvers      Float   @default(0)
  currentBowlerId String?
  nonStrikerId    String?
  strikerId       String?
  battingTeam     Team    @relation("battingTeam", fields: [battingTeamId], references: [id])
  bowlingTeam     Team    @relation("bowlingTeam", fields: [bowlingTeamId], references: [id])
  match           Match   @relation(fields: [matchId], references: [id])
  oversData       Over[]

  @@unique([matchId, inningNumber])
}

model Over {
  id         String @id @default(cuid())
  inningId   String
  overNumber Int
  bowlerId   String
  runs       Int    @default(0)
  extras     Int    @default(0)
  wickets    Int    @default(0)
  balls      Ball[]
  bowler     Player @relation(fields: [bowlerId], references: [id])
  inning     Inning @relation(fields: [inningId], references: [id])

  @@unique([inningId, overNumber])
  @@index([bowlerId])
}

model Ball {
  id                String  @id @default(cuid())
  overId            String
  ballNumber        Int
  batterId          String
  nonStrikerId      String
  runs              Int     @default(0)
  extras            Int     @default(0)
  extraType         String?
  isWicket          Boolean @default(false)
  wicketType        String?
  wicketAssists     String?
  dismissedPlayerId String?
  clientEventId     String? @unique
  bowlerId          String?
  batter            Player  @relation("facingBatter", fields: [batterId], references: [id])
  bowler            Player? @relation("ballBowler", fields: [bowlerId], references: [id])
  nonStriker        Player  @relation("nonStriker", fields: [nonStrikerId], references: [id])
  over              Over    @relation(fields: [overId], references: [id])

  @@index([overId])
  @@index([batterId])
  @@index([bowlerId])
  @@index([dismissedPlayerId])
}

model News {
  id        String   @id @default(cuid())
  // Each sport is its own world in this app — content is scoped to one.
  sport     String   @default("cricket")
  createdAt DateTime @default(now())
  title     String
  summary   String
  body      String
  author    String?
  category  String?

  @@index([sport])
}

model Product {
  id          String   @id @default(cuid())
  // Each sport is its own world in this app — content is scoped to one.
  sport       String   @default("cricket")
  createdAt   DateTime @default(now())
  title       String
  description String
  price       Int
  category    String
  location    String?
  sellerId    String
  images      Json?
  seller      User     @relation(fields: [sellerId], references: [id])

  @@index([sport])
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Pincode {
  id       Int    @id @default(autoincrement())
  office   String
  pincode  String
  district String
  state    String

  @@index([office])
  @@index([pincode])
  @@index([pincode], map: "pincode_pin_prefix_idx")
}

model GalleryPhoto {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  url       String
  caption   String?
  userId    String?
  teamId    String?
  matchId   String?

  @@index([userId, createdAt])
  @@index([teamId, createdAt])
  @@index([matchId])
}

model Badge {
  id          String      @id @default(cuid())
  title       String
  description String
  icon        String?
  points      Int         @default(0)
  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  badge    Badge    @relation(fields: [badgeId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
}

model Tournament {
  id          String            @id @default(cuid())
  createdAt   DateTime          @default(now())
  name        String
  format      String
  status      String
  startDate   DateTime?
  endDate     DateTime?
  venue       String?
  maxTeams    Int?
  prizePool   String?
  description String?
  organizer   String?
  sport       String            @default("cricket")
  ballType    String?
  overs       Int?
  championId  String?
  organizerId String?
  matches     TournamentMatch[]
  teams       TournamentTeam[]

  @@index([sport])
}

model Stream {
  id          String   @id @default(cuid())
  // Each sport is its own world in this app — content is scoped to one.
  sport       String   @default("cricket")
  title       String
  description String?
  matchId     String?
  channel     String
  isPrivate   Boolean  @default(false)
  quality     String
  status      String   @default("upcoming")
  createdAt   DateTime @default(now())

  @@index([sport])
}

model Ground {
  id         String    @id @default(cuid())
  name       String
  location   String
  price      Int
  available  Boolean   @default(true)
  facilities Json?
  sport      String    @default("cricket")
  bookings   Booking[]

  @@index([sport])
}

model Booking {
  id        String   @id @default(cuid())
  groundId  String
  userId    String
  date      DateTime
  slot      String
  createdAt DateTime @default(now())
  ground    Ground   @relation(fields: [groundId], references: [id])

  @@index([userId])
  @@index([groundId])
}

model Quiz {
  id          String       @id @default(cuid())
  // Each sport is its own world in this app — content is scoped to one.
  sport       String       @default("cricket")
  title       String
  description String?
  difficulty  String       @default("Medium")
  duration    Int          @default(300)
  questions   Json
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  results     QuizResult[]

  @@index([sport])
}

model QuizResult {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  score     Int
  total     Int
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id])
}

model Club {
  id            String   @id @default(cuid())
  // Each sport is its own world in this app — content is scoped to one.
  sport         String   @default("cricket")
  createdAt     DateTime @default(now())
  name          String
  president     String?
  secretary     String?
  foundedYear   Int?
  address       String?
  city          String?
  state         String?
  country       String?
  phone         String?
  email         String?
  website       String?
  membershipFee String?
  facilities    Json?
  bio           String?

  @@index([sport])
}

model ChatRoom {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  name      String
  type      String        @default("team")
  members   ChatMember[]
  messages  ChatMessage[]
}

model ChatMember {
  id         String    @id @default(cuid())
  chatRoomId String
  userId     String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?
  chatRoom   ChatRoom  @relation(fields: [chatRoomId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@unique([chatRoomId, userId])
}

model ChatMessage {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  chatRoomId String
  senderId   String
  text       String
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id])
  sender     User     @relation(fields: [senderId], references: [id])
}

model Video {
  id           String         @id @default(cuid())
  createdAt    DateTime       @default(now())
  title        String
  matchId      String?
  uploadUrl    String?
  thumbnailUrl String?
  duration     String?
  status       String         @default("uploaded")
  analysis     VideoAnalysis?
}

model VideoAnalysis {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  videoId    String   @unique
  highlights Int      @default(0)
  shots      Int      @default(0)
  insights   Int      @default(0)
  details    Json?
  video      Video    @relation(fields: [videoId], references: [id])
}

model LookingFor {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  type        String
  title       String
  description String?
  location    String?
  format      String?
  ageGroup    String?
  contactInfo String?
  postedById  String?
  status      String   @default("open")
  sport       String   @default("cricket")

  @@index([sport, status])
  @@index([type])
}

model LookingForConnection {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  listingId   String
  requesterId String
  posterId    String
  status      String   @default("pending")
  chatRoomId  String?

  @@unique([listingId, requesterId])
  @@index([posterId, status])
  @@index([requesterId])
}

model Coach {
  id           String         @id @default(cuid())
  createdAt    DateTime       @default(now())
  name         String
  speciality   String?
  experience   Int?
  location     String?
  bio          String?
  rating       Float          @default(0)
  pricePerHour Int?
  available    Boolean        @default(true)
  bookings     CoachBooking[]
}

model CoachBooking {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  coachId   String
  userId    String
  date      DateTime
  duration  Int      @default(1)
  notes     String?
  status    String   @default("pending")
  coach     Coach    @relation(fields: [coachId], references: [id])
}

model Umpire {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  name           String
  level          String?
  experience     Int?
  location       String?
  bio            String?
  available      Boolean  @default(true)
  contactInfo    String?
  matchesUmpired Int      @default(0)
}

model Scorer {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())
  name        String
  experience  Int?
  location    String?
  available   Boolean         @default(true)
  contactInfo String?
  bookings    ScorerBooking[]
}

model ScorerBooking {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  scorerId  String
  userId    String
  matchDate DateTime
  venue     String?
  status    String   @default("pending")
  scorer    Scorer   @relation(fields: [scorerId], references: [id])
}

model TournamentTeam {
  id            String     @id @default(cuid())
  createdAt     DateTime   @default(now())
  tournamentId  String
  teamId        String
  points        Int        @default(0)
  played        Int        @default(0)
  won           Int        @default(0)
  lost          Int        @default(0)
  tied          Int        @default(0)
  nrr           Float      @default(0)
  group         String     @default("A")
  stats         Json?
  status        String     @default("approved")
  requestedById String?
  chatRoomId    String?
  requestNote   String?
  team          Team       @relation(fields: [teamId], references: [id])
  tournament    Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([tournamentId, teamId])
}

model TournamentMatch {
  id           String           @id @default(cuid())
  createdAt    DateTime         @default(now())
  tournamentId String
  matchId      String?
  team1Id      String?
  team2Id      String?
  scheduledAt  DateTime?
  venue        String?
  round        String?
  result       String?
  status       String           @default("scheduled")
  leg          Int?
  phaseId      String?
  resultKind   String?
  resultStats  Json?
  seriesId     String?
  winnerTeamId String?
  placeholder1 String?
  placeholder2 String?
  phase        TournamentPhase? @relation(fields: [phaseId], references: [id])
  tournament   Tournament       @relation(fields: [tournamentId], references: [id])
}

model MatchMVP {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  matchId   String
  playerId  String
  teamId    String
  reason    String?
  votes     Int      @default(0)
}

model Post {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  sport        String    @default("cricket")
  authorId     String?
  authorName   String
  team         String?
  text         String
  likes        Int       @default(0)
  authorAvatar String?
  mediaUrl     String?
  comments     Comment[]

  @@index([sport, createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  postId     String
  authorId   String?
  authorName String
  text       String
  post       Post     @relation(fields: [postId], references: [id])

  @@index([postId, createdAt])
}

model RummyGame {
  id            String        @id @default(cuid())
  createdAt     DateTime      @default(now())
  userId        String?
  name          String
  totalScore    Int           @default(250)
  openDrop      Int           @default(25)
  middleDrop    Int           @default(50)
  fullCount     Int           @default(80)
  adjustReentry Boolean       @default(false)
  status        String        @default("active")
  players       RummyPlayer[]
  rounds        RummyRound[]

  @@index([userId, createdAt])
  @@index([status])
}

model RummyPlayer {
  id       String       @id @default(cuid())
  gameId   String
  name     String
  position Int          @default(0)
  game     RummyGame    @relation(fields: [gameId], references: [id])
  scores   RummyScore[]

  @@index([gameId])
}

model RummyRosterPlayer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String?
  name      String

  @@unique([userId, name])
  @@index([userId])
}

model RummyRound {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())
  gameId      String
  roundNumber Int
  game        RummyGame    @relation(fields: [gameId], references: [id])
  scores      RummyScore[]

  @@unique([gameId, roundNumber])
}

model RummyScore {
  id       String      @id @default(cuid())
  roundId  String
  playerId String
  value    Int
  player   RummyPlayer @relation(fields: [playerId], references: [id])
  round    RummyRound  @relation(fields: [roundId], references: [id])

  @@index([roundId])
  @@index([playerId])
}

model SportConfiguration {
  id        String   @id
  name      String
  icon      String?
  color     String?
  accent    String?
  rules     Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
}

model TournamentPhase {
  id           String            @id @default(cuid())
  tournamentId String
  order        Int               @default(0)
  type         String
  name         String
  config       Json?
  matches      TournamentMatch[]

  @@index([tournamentId])
}

model MatchSubstitution {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  matchId     String
  teamId      String
  playerOutId String
  playerInId  String
  period      String?

  @@index([matchId, teamId])
}

model ActivityFeed {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  type         String
  sport        String
  actorId      String?
  subjectType  String?
  subjectId    String?
  payload      Json
  likes        Int      @default(0)
  commentCount Int      @default(0)

  @@index([sport, createdAt])
  @@index([subjectType, subjectId, createdAt])
}

model Like {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String
  targetType String
  targetId   String

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}
