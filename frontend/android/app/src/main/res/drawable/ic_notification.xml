<!--
  Notification small icon — the ✦ sparkle from the LOCAL ✦ LEGENDS wordmark.

  Android renders small icons from the ALPHA CHANNEL ONLY: the shape is filled
  with the system/accent colour and everything else is discarded. So the full
  launcher icon can't be used here — its wordmark would collapse into an
  illegible white blob (which is exactly what the default fallback produced).
  The sparkle is the one mark in the brand that still reads at 24dp.

  Solid white on transparent, 24dp, per the Material notification-icon spec.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Four-pointed sparkle, centred; concave edges keep the points crisp. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M12,1.5 C12.65,7.35 16.65,11.35 22.5,12 C16.65,12.65 12.65,16.65 12,22.5 C11.35,16.65 7.35,12.65 1.5,12 C7.35,11.35 11.35,7.35 12,1.5 Z" />

    <!-- Small companion spark, upper-right — echoes the badge's twinkle. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M19.6,2.6 C19.8,4.35 20.65,5.2 22.4,5.4 C20.65,5.6 19.8,6.45 19.6,8.2 C19.4,6.45 18.55,5.6 16.8,5.4 C18.55,5.2 19.4,4.35 19.6,2.6 Z" />
</vector>
